# ─── E-mail (Resend) ─────────────────────────────────────────────
# 1. Crie uma conta gratuita em https://resend.com
# 2. Gere uma API key em https://resend.com/api-keys
# 3. Verifique o domínio montsteel.com.br em https://resend.com/domains
#    (enquanto não verificar, mantenha EMAIL_FROM como onboarding@resend.dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="MontSteel <onboarding@resend.dev>"
EMAIL_TO=contato@montsteel.com.br

# ─── Site ────────────────────────────────────────────────────────
# URL pública usada em sitemap, robots e metadados OpenGraph.
NEXT_PUBLIC_SITE_URL=https://www.montsteel.com.br

# Blog em WordPress Headless. URL base da API REST (wp/v2) do site WordPress
# usado como fonte de conteúdo das páginas /blog e /blog/[slug].
NEXT_PUBLIC_WORDPRESS_API_URL=https://public-api.wordpress.com/wp/v2/sites/seu-site.wordpress.com

# Token secreto usado por /api/revalidate para forçar a atualização do blog
# sob demanda (ex.: webhook do WordPress ao publicar um post). Gere um valor
# aleatório forte, por exemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVALIDATION_TOKEN=troque-por-um-token-aleatorio-forte

# ─── Google Analytics 4 (opcional) ───────────────────────────────
# ID de medição (formato G-XXXXXXXXXX). Deixe vazio para desativar.
NEXT_PUBLIC_GA_ID=
