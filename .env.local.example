# ─── E-mail (Resend) ─────────────────────────────────────────────
# 1. Crie uma conta gratuita em https://resend.com
# 2. Gere uma API key em https://resend.com/api-keys
# 3. Verifique o domínio cobersteel.com.br em https://resend.com/domains
#    (enquanto não verificar, mantenha EMAIL_FROM como onboarding@resend.dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="CoberSteel <onboarding@resend.dev>"
EMAIL_TO=contato@cobersteel.com.br

# ─── Site ────────────────────────────────────────────────────────
# URL pública usada em sitemap, robots e metadados OpenGraph.
NEXT_PUBLIC_SITE_URL=https://www.cobersteel.com.br

# Blog em WordPress (subdomínio). O link "Blog" do menu aponta para cá.
NEXT_PUBLIC_BLOG_URL=https://blog.cobersteel.com.br

# ─── Google Analytics 4 (opcional) ───────────────────────────────
# ID de medição (formato G-XXXXXXXXXX). Deixe vazio para desativar.
NEXT_PUBLIC_GA_ID=
